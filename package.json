{
  "name": "condo-manager",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css}\"",
    "test": "vitest",
    "test:e2e": "node node_modules/@playwright/test/cli.js test",
    "worker": "tsx watch worker/index.ts",
    "seed:contractors": "tsx prisma/seed-contractors.ts",
    "seed:marketplace-mock": "tsx prisma/seed-marketplace-mock.ts",
    "seed:demo": "tsx prisma/seed-demo.ts",
    "seed:features": "tsx prisma/sync-features.ts",
    "pitch:screenshots": "node scripts/take-pitch-screenshots.mjs",
    "pitch:dev": "slidev docs/pitch/slides.md --open",
    "pitch:build": "slidev build docs/pitch/slides.md --out dist --base ./",
    "pitch:export": "slidev export docs/pitch/slides.md --output docs/pitch/condo-manager-pitch.pdf",
    "dbml": "prisma generate && node scripts/clean-dbml.mjs",
    "postinstall": "prisma generate && node scripts/clean-dbml.mjs"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "@react-pdf/renderer": "^4.5.1",
    "@types/qrcode": "^1.5.6",
    "@uiw/react-md-editor": "^4.1.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.34.0",
    "dompurify": "^3.3.3",
    "ioredis": "^5.6.0",
    "lucide-react": "^0.474.0",
    "next": "15.3.1",
    "next-auth": "5.0.0-beta.25",
    "next-intl": "^4.1.0",
    "nodemailer": "^6.10.0",
    "otplib": "^13.4.0",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "stripe": "^21.0.1",
    "web-push": "^3.6.7",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@playwright/test": "^1.58.2",
    "@slidev/cli": "^52.15.2",
    "@slidev/theme-default": "^0.25.0",
    "@tailwindcss/postcss": "^4.1.3",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.14.1",
    "@types/nodemailer": "^6.4.17",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@types/web-push": "^3.6.4",
    "eslint": "^9.24.0",
    "eslint-config-next": "15.3.1",
    "eslint-config-prettier": "^10.1.0",
    "playwright-chromium": "^1.60.0",
    "postcss": "^8.5.3",
    "prettier": "^3.5.3",
    "prisma": "^6.5.0",
    "prisma-dbml-generator": "^0.12.0",
    "tailwindcss": "^4.1.3",
    "tsx": "^4.19.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  }
}
