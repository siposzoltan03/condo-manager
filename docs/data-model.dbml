  sortOrder Int [not null, default: 0]
  isDefault Boolean [not null, default: false, note: 'True for built-in defaults (cannot be deleted, can be renamed).']
  isActive Boolean [not null, default: true, note: 'Soft-toggle to hide a category without breaking historical rows.']
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]
  complaints Complaint [not null]

  indexes {
    (buildingId, slug) [unique]
  }

  Note: 'Per-building, board-managed taxonomy. Default rows have isDefault=true
and cannot be deleted (only renamed or hidden via isActive=false).'
}

Table ComplaintStatusEvent {
  id String [pk]
  complaint Complaint [not null]
  complaintId String [not null]
  fromStatus ComplaintStatus
  toStatus ComplaintStatus [not null]
  actor User [not null, note: 'Who triggered the transition.']
  actorId String [not null]
  note String [note: 'Optional free-text note for the transition (e.g. warning letter contents).']
  createdAt DateTime [default: `now()`, not null]

  Note: 'Status-transition log for the mediation timeline. Auto-recorded on
every complaint.status change.'
}

Table PendingAgendaItem {
  id String [pk]
  building Building [not null]
  buildingId String [not null]
  kind PendingAgendaKind [not null]
  title String [not null, note: 'Display title rendered in the meeting agenda + the pending inbox.']
  description String
  complaint Complaint [note: 'Polymorphic source.']
  complaintId String [unique]
  resignation BoardResignation
  resignationId String [unique]
  createdBy User [not null]
  createdById String [not null]
  attachedMeeting Meeting [note: 'Null = still queued. Set when the board attaches it to a meeting.']
  attachedMeetingId String
  resolutionNote String [note: 'Free-text resolution captured when the board explicitly checks the
item off (typically after the meeting).']
  resolvedAt DateTime
  resolvedBy User
  resolvedById String
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  Note: 'Cross-cutting "needs to be tabled at közgyűlés" queue.

Polymorphic source — exactly one of complaintId / resignationId is set
per kind. Items start with attachedMeetingId=null; the board picks them
off the queue when scheduling / editing a meeting. After the meeting,
the board explicitly marks each item resolved with an optional note.'
}

Table ComplaintNote {
  id String [pk]
  complaint Complaint [not null]
  complaintId String [not null]
  author User [not null]
  authorId String [not null]
  body String [not null]
  isInternal Boolean [not null, default: false]
  createdAt DateTime [default: `now()`, not null]
}

Table MaintenanceTicket {
  id String [pk]
  reporterId String [not null]
  reporter User [not null]
  title String [not null]
  description String [not null]
  category MaintenanceCategory [not null]
  location String
  urgency Urgency [not null]
  status TicketStatus [not null, default: 'SUBMITTED']
  slaHours Int [note: 'Hours until SLA breach, set at creation. null = no SLA tracking.']
  trackingNumber String [unique, not null]
  assignedContractorId String
  assignedContractor Contractor
  awardedContractorId String [note: 'New marketplace-awarded contractor (separate from the legacy
`assignedContractor` directory FK, which we keep for historical rows).']
  awardedContractor ContractorOrg
  publication MarketplacePublication
  building Building [not null]
  buildingId String [not null]
  scheduledMaintenance ScheduledMaintenance [note: 'Set when this ticket was auto-materialized from a scheduled entry.']
  scheduledMaintenanceId String
  comments TicketComment [not null]
  attachments TicketAttachment [not null]
  ratings ContractorRating [not null]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]
}

Table TicketComment {
  id String [pk]
  ticketId String [not null]
  ticket MaintenanceTicket [not null]
  authorId String [not null]
  author User [not null]
  body String [not null]
  isInternal Boolean [not null, default: false]
  createdAt DateTime [default: `now()`, not null]
}

Table TicketAttachment {
  id String [pk]
  ticketId String [not null]
  ticket MaintenanceTicket [not null]
  fileUrl String [not null]
  fileName String [not null]
  createdAt DateTime [default: `now()`, not null]
}

Table Contractor {
  id String [pk]
  name String [not null]
  specialty String [not null]
  contactInfo String [not null]
  taxId String
  tickets MaintenanceTicket [not null]
  ratings ContractorRating [not null]
  contractorOrg ContractorOrg [note: 'Back-link if this directory row has been claimed by a registered
`ContractorOrg`. Null = legacy unclaimed.']
  dataProcessingAgreementDocumentId String [note: 'Phase 5 — GDPR Art. 28. Pointer to the Data Processing Agreement
(adatfeldolgozói szerződés) stored as a Document. Ticket assignment
is blocked for contractors with no DPA on file.']
  dataProcessingAgreementDocument Document
  createdAt DateTime [default: `now()`, not null]
}

Table ContractorOrg {
  id String [pk]
  name String [not null]
  taxId String [unique, not null, note: 'HU tax id (adószám), validated at onboarding.']
  navConfirmedAt DateTime [note: 'Filled when the NAV adószám-validation API confirms registration.']
  specialties Json [not null, default: '[]', note: 'JSON list of specialty slugs ("plumbing", "electrical", "elevator", ...).']
  regions Json [not null, default: '[]', note: 'JSON list of HU county / Budapest district codes the org will travel to.']
  description String
  websiteUrl String
  logoUrl String
  documents ContractorDocument [not null]
  stripeCustomerId String [unique, note: 'Stripe customer for contractor-side billing.']
  stripeSubscriptionId String [unique, note: 'Stripe subscription id when org is on PRO or PREMIUM.']
  plan ContractorPlan [not null, default: 'FREE']
  planStatus String [not null, default: 'ACTIVE', note: '"TRIALING" | "ACTIVE" | "PAST_DUE" | "CANCELLED".']
  trialEndsAt DateTime [note: 'When the current Pro trial ends. After this we lazily downgrade to FREE.']
  currentPeriodEndsAt DateTime [note: 'Current Stripe billing period end — surfaced in the billing UI.']
  status ContractorOrgStatus [not null, default: 'PENDING_VERIFICATION']
  users ContractorUser [not null]
  bids MarketplaceBid [not null]
  awardedTickets MaintenanceTicket [not null]
  ratings ContractorRating [not null]
  messages MarketplaceMessage [not null]
  legacyContractorId String [unique, note: 'One-to-one back-link to the legacy `Contractor` directory row when
a board has worked with this contractor before signing up.']
  legacyContractor Contractor
  dpaSignedAt DateTime [note: 'Marker the user accepted the DPA + ToS during onboarding.']
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  Note: 'A vendor business signing up to bid on `MaintenanceTicket`s published
to the marketplace. Independent of `UserBuilding` — orgs operate
across many condos.'
}

Table ContractorUser {
  id String [pk]
  org ContractorOrg [not null]
  orgId String [not null]
  email String [unique, not null]
  passwordHash String [not null]
  name String [not null]
  phone String
  role ContractorUserRole [not null, default: 'OWNER']
  emailVerifiedAt DateTime
  isActive Boolean [not null, default: true]
  notificationPreferences Json [not null, default: '{}']
  notifications Notification [not null]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  Note: 'Login identity scoped to a contractor org. Lives in a parallel auth
tree from `User` — one email belongs to either tree, never both.'
}

Table ContractorDocument {
  id String [pk]
  org ContractorOrg [not null]
  orgId String [not null]
  kind String [not null, note: '"insurance" | "license" | "reference" | "other".']
  storageKey String [not null]
  fileName String [not null]
  validUntil DateTime [note: 'Optional expiry — surfaced to condos as "valid through".']
  createdAt DateTime [default: `now()`, not null]

  Note: 'Insurance / license / reference docs uploaded by the contractor.'
}

Table MarketplacePublication {
  id String [pk]
  ticket MaintenanceTicket [not null]
  ticketId String [unique, not null]
  status MarketplacePublishStatus [not null, default: 'OPEN']
  scrubbedTitle String [not null, note: 'Frozen at publish time — the listing service does NOT re-read.']
  scrubbedDescription String [not null]
  category String [not null]
  urgency String [not null]
  city String [not null]
  zip String [not null]
  budgetBand String [note: '"<100K", "100K-500K", "500K-2M", "2M+", or null.']
  deadlineAt DateTime
  specialties Json [not null, default: '[]', note: 'JSON list of specialty slugs this publication accepts bids for.']
  revealAddressOnAward Boolean [not null, default: true, note: 'Per-publisher privacy toggles, decided at publish time.']
  revealUnitOnAward Boolean [not null, default: false]
  revealOwnerPhoneOnAward Boolean [not null, default: false]
  boardContactEmail String [not null, note: 'Board contact surfaced to the winning bidder.']
  boardContactPhone String
  publishedAt DateTime [default: `now()`, not null]
  publishedById String [not null]
  publishedBy User [not null]
  bids MarketplaceBid [not null]
  messages MarketplaceMessage [not null]
  fitScores MarketplaceFitScore [not null]
  awardedBidId String [unique, note: 'Awarded counterpart (set when status becomes AWARDED).']
  awardedBid MarketplaceBid
  awardedAt DateTime
  closedAt DateTime
  closeReason String
  publisherDisplayName String [not null, note: 'Per-publication snapshot of (publisher\'s display name, building city)
so historical aggregates remain meaningful after a publisher leaves
the board or a building renames itself.']

  Note: 'Scrubbed projection of a `MaintenanceTicket` exposed to the
marketplace. The contractor side ONLY reads this row — never the
underlying ticket — so PII can\'t leak by accident.'
}

Table MarketplaceBid {
  id String [pk]
  publication MarketplacePublication [not null]
  publicationId String [not null]
  bidder ContractorOrg [not null]
  bidderId String [not null]
  amount Decimal [not null, note: 'Net Ft amount.']
  etaDays Int [not null, note: 'Estimated days to completion from award.']
  notes String [note: 'Plain-text bidder narrative — capped at 800 chars in the route.']
  status MarketplaceBidStatus [not null, default: 'SUBMITTED']
  decidedAt DateTime
  decidedById String
  decisionReason String [note: 'Free-text reason; required per P2B Art. 4 on rejection.']
  awardedFor MarketplacePublication
  fitScore MarketplaceFitScore
  invoice MarketplaceInvoice
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  indexes {
    (publicationId, bidderId) [unique]
  }
}

Table MarketplaceInvoice {
  id String [pk]
  bid MarketplaceBid [not null]
  bidId String [unique, not null]
  invoiceNumber String [not null]
  grossAmount Decimal [not null, note: 'Gross (VAT-included) Ft amount as written on the invoice.']
  issuedAt DateTime [not null]
  dueAt DateTime [not null]
  storageKey String [note: 'Optional PDF; rest of the metadata is mandatory.']
  fileName String
  status MarketplaceInvoiceStatus [not null, default: 'PENDING']
  paidAt DateTime
  paidById String
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  Note: 'One-to-one invoice attached to a WON bid. Contractor submits;
board flips PENDING → PAID, which is what advances the linked
ticket from COMPLETED → VERIFIED.'
}

Table MarketplaceMessage {
  id String [pk]
  publication MarketplacePublication [not null]
  publicationId String [not null]
  bidder ContractorOrg [not null]
  bidderId String [not null]
  senderSide String [not null, note: '"BOARD" or "CONTRACTOR".']
  senderId String [not null, note: 'userId on the condo side OR contractorUserId on the contractor side.']
  body String [not null]
  readAt DateTime
  createdAt DateTime [default: `now()`, not null]

  Note: 'Anonymous board ↔ contractor thread scoped to one (publication, bidder)
pair. Plain-text only.'
}

Table MarketplaceFitScore {
  id String [pk]
  publication MarketplacePublication [not null]
  publicationId String [not null]
  bid MarketplaceBid [not null]
  bidId String [unique, not null]
  score Int [not null, note: '0–100 composite.']
  rationale String [not null, note: 'Templated Hungarian sentence shown under the bid card.']
  weightsVersion String [not null, note: 'Versioned scoring weights id, e.g. "v1.0.0".']
  factorsJson Json [not null, note: 'Frozen factor values used to compute this score.']
  computedAt DateTime [default: `now()`, not null]

  Note: 'Best-fit score cached per (publication, bid). Rule-based — no LLM.
`weightsVersion` + `factorsJson` make the rationale reproducible.'
}

Table ContractorRating {
  id String [pk]
  contractorId String [note: 'Legacy contractor directory rating. Mutually exclusive with
`contractorOrgId` — exactly one is set, enforced in app code.']
  contractor Contractor
  contractorOrgId String [note: 'Marketplace contractor rating, set on COMPLETED tickets that
were awarded via `MarketplacePublication`.']
  contractorOrg ContractorOrg
  ticketId String [not null]
  ticket MaintenanceTicket [not null]
  raterId String [not null]
  rater User [not null]
  rating Int [not null]
  notes String
  createdAt DateTime [default: `now()`, not null]
}

Table ScheduledMaintenance {
  id String [pk]
  title String [not null]
  description String
  date DateTime [not null, note: 'Next due date. For recurring entries, advanced after each materialization.']
  isRecurring Boolean [not null, default: false]
  recurrenceMonths Int [note: 'Months between occurrences when recurring (e.g. 1=monthly, 12=yearly).']
  leadTimeDays Int [not null, default: 7, note: 'Days before `date` to materialize a ticket. Default 7.']
  materializedAt DateTime [note: 'When the most recent ticket was materialized from this entry.']
  building Building [not null]
  buildingId String [not null]
  tickets MaintenanceTicket [not null, note: 'Tickets generated from this scheduled entry.']
  createdAt DateTime [default: `now()`, not null]
}

Table Account {
  id String [pk]
  name String [not null]
  type AccountType [not null]
  parentId String
  parent Account
  children Account [not null]
  building Building [not null]
  buildingId String [not null]
  createdAt DateTime [default: `now()`, not null]
  debitEntries LedgerEntry [not null]
  creditEntries LedgerEntry [not null]
  budgets Budget [not null]
}

Table LedgerEntry {
  id String [pk]
  date DateTime [not null]
  debitAccountId String [not null]
  debitAccount Account [not null]
  creditAccountId String [not null]
  creditAccount Account [not null]
  amount Decimal [not null]
  description String [not null]
  receiptUrl String
  createdById String [not null]
  createdBy User [not null]
  createdAt DateTime [default: `now()`, not null]
}

Table MonthlyCharge {
  id String [pk]
  unitId String [not null]
  unit Unit [not null]
  month String [not null]
  amount Decimal [not null]
  status ChargeStatus [not null, default: 'UNPAID']
  paidAt DateTime
  createdAt DateTime [default: `now()`, not null]

  indexes {
    (unitId, month) [unique]
  }
}

Table Budget {
  id String [pk]
  year Int [not null]
  accountId String [not null]
  account Account [not null]
  plannedAmount Decimal [not null]

  indexes {
    (year, accountId) [unique]
  }
}

Table Meeting {
  id String [pk]
  title String [not null]
  description String
  date DateTime [not null]
  time String [not null]
  location String
  agenda Json [not null, default: '[]']
  minutes String
  minutesUpdatedAt DateTime
  minutesUpdatedBy User
  minutesUpdatedById String
  createdBy User [not null]
  createdById String [not null]
  building Building [not null]
  buildingId String [not null]
  isRepeated Boolean [not null, default: false]
  rsvps MeetingRsvp [not null]
  attendances MeetingAttendance [not null]
  votes Vote [not null]
  pendingAgenda PendingAgendaItem [not null, note: 'Pending agenda items (resignations + escalated complaints) attached
to this meeting. Source-of-truth for meeting agenda integration.']
  minutesSignatures MeetingMinutesSignature [not null, note: 'Chair + two-authenticator signatures on the jegyzőkönyv.']
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]
}

Table MeetingRsvp {
  id String [pk]
  meeting Meeting [not null]
  meetingId String [not null]
  user User [not null]
  userId String [not null]
  status RsvpStatus [not null]
  createdAt DateTime [default: `now()`, not null]

  indexes {
    (meetingId, userId) [unique]
  }
}

Table MeetingAttendance {
  id String [pk]
  meeting Meeting [not null]
  meetingId String [not null]
  unit Unit [not null]
  unitId String [not null]
  checkedIn Boolean [not null, default: true]
  checkedInAt DateTime [default: `now()`, not null]
  checkedOutAt DateTime
  createdAt DateTime [default: `now()`, not null]

  indexes {
    (meetingId, unitId) [unique]
  }
}

Table Vote {
  id String [pk]
  title String [not null]
  description String
  voteType VoteType [not null, default: 'YES_NO']
  status VoteStatus [not null, default: 'DRAFT']
  isSecret Boolean [not null, default: false]
  majorityType MajorityType [not null, default: 'SIMPLE_MAJORITY']
  quorumRequired Decimal [not null]
  deadline DateTime [not null]
  building Building [not null]
  buildingId String [not null]
  meeting Meeting
  meetingId String
  createdBy User [not null]
  createdById String [not null]
  options VoteOption [not null]
  ballots Ballot [not null]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]
}

Table VoteOption {
  id String [pk]
  vote Vote [not null]
  voteId String [not null]
  label String [not null]
  sortOrder Int [not null, default: 0]
  ballots Ballot [not null]
}

Table Ballot {
  id String [pk]
  vote Vote [not null]
  voteId String [not null]
  option VoteOption [not null]
  optionId String [not null]
  unit Unit [not null]
  unitId String [not null]
  user User
  userId String
  castBy User
  castById String
  weight Decimal [not null]
  receiptHash String
  createdAt DateTime [default: `now()`, not null]

  indexes {
    (voteId, unitId) [unique]
  }
}

Table ProxyAssignment {
  id String [pk]
  grantor User [not null]
  grantorId String [not null]
  grantee User [not null]
  granteeId String [not null]
  voteId String
  validFrom DateTime [default: `now()`, not null]
  validUntil DateTime
  createdAt DateTime [default: `now()`, not null]
}

Table DocumentCategory {
  id String [pk]
  name String [not null]
  icon String
  parentId String
  parent DocumentCategory
  children DocumentCategory [not null]
  sortOrder Int [not null, default: 0]
  building Building [not null]
  buildingId String [not null]
  documents Document [not null]
  createdAt DateTime [default: `now()`, not null]
}

Table Document {
  id String [pk]
  title String [not null]
  description String
  category DocumentCategory [not null]
  categoryId String [not null]
  visibility DocumentVisibility [not null, default: 'PUBLIC']
  tags Json [not null, default: '[]']
  isArchived Boolean [not null, default: false]
  isPinned Boolean [not null, default: false, note: 'Pinned to the top of its category as a featured document.']
  expiresAt DateTime [note: 'Expiry date for contracts / licenses. Null means no expiry.']
  viewCount Int [not null, default: 0, note: 'Audit counters (incremented when the version panel opens / a download fires).']
  downloadCount Int [not null, default: 0]
  lastAccessedAt DateTime
  uploadedBy User [not null]
  uploadedById String [not null]
  versions DocumentVersion [not null]
  contractorDpas Contractor [not null, note: 'Phase 5 — back-relation for Contractor DPA pointers (GDPR Art. 28).']
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]
}

Table DocumentVersion {
  id String [pk]
  document Document [not null]
  documentId String [not null]
  versionNumber Int [not null]
  fileUrl String [not null]
  fileName String [not null]
  fileSize Int [not null]
  mimeType String [not null]
  extractedText String
  uploadedBy User [not null]
  uploadedById String [not null]
  uploadedAt DateTime [default: `now()`, not null]

  indexes {
    (documentId, versionNumber) [unique]
  }
}

Table PushSubscription {
  id String [pk]
  user User [not null]
  userId String [not null]
  endpoint String [unique, not null]
  p256dh String [not null]
  auth String [not null]
  createdAt DateTime [default: `now()`, not null]
}

Table MeetingMinutesSignature {
  id String [pk]
  meeting Meeting [not null]
  meetingId String [not null]
  signer User [not null]
  signerId String [not null]
  role MinutesSignatureRole [not null]
  signedAt DateTime [default: `now()`, not null]
  ipAddress String [note: 'Best-effort IP capture for after-the-fact dispute resolution.
Null when the request didn\'t expose one.']

  indexes {
    (meetingId, role) [unique]
  }

  Note: 'Tht. § 39 mandates that a meeting\'s jegyzőkönyv carries the
chair\'s signature and two authenticators (hitelesítők). One row per
(meeting, role); the unique constraint enforces "exactly three slots".
Once all three are present the minutes are "executed" and the latest
jegyzőkönyv PDF is the legally-binding copy.'
}

Table GeneratedReport {
  id String [pk]
  building Building [not null]
  buildingId String [not null]
  kind String [not null]
  period String [not null, note: 'Opaque identifier per kind, e.g. "vote-{voteId}" or "meeting-{meetingId}".']
  contentHash String [not null, note: 'SHA-256 over the input data used to render the PDF — drives dedupe.']
  status ReportStatus [not null, default: 'PENDING']
  storageKey String [note: 'Storage key under the configured driver (null until READY).']
  fileSize Int [note: 'Bytes of the rendered PDF (null until READY). Surfaced in download UI.']
  errorMessage String [note: 'Last failure message (set when status=FAILED).']
  generatedBy User [not null]
  generatedById String [not null]
  generatedAt DateTime [default: `now()`, not null]
  finishedAt DateTime
  isDraft Boolean [not null, default: false]
  retainUntil DateTime [note: 'Retention horizon — null means forever (legal-mandated reports).']

  indexes {
    (buildingId, kind, period, contentHash) [unique]
  }

  Note: 'Cached server-rendered PDF reports.

Dedup is keyed on `(buildingId, kind, period, contentHash)`: if a row
exists with status=READY, callers reuse it. PENDING/RUNNING rows act as
in-flight markers so concurrent generate-requests share a single job.'
}

Enum ComplaintStatus {
  REPORTED
  ACKNOWLEDGED
  WARNING_SENT
  MEDIATION
  RESOLVED
  ESCALATED
}

Enum MaintenanceCategory {
  PLUMBING
  ELECTRICAL
  STRUCTURAL
  COMMON_AREA
  ELEVATOR
  HEATING
  OTHER
}

Enum Urgency {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

Enum TicketStatus {
  SUBMITTED
  ACKNOWLEDGED
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  VERIFIED
}

Enum AccountType {
  ASSET
  LIABILITY
  INCOME
  EXPENSE
}

Enum ChargeStatus {
  PAID
  UNPAID
  OVERDUE
}

Enum VoteType {
  YES_NO
  MULTIPLE_CHOICE
  RANKED_CHOICE
}

Enum VoteStatus {
  DRAFT
  OPEN
  CLOSED
}

Enum RsvpStatus {
  ATTENDING
  NOT_ATTENDING
  PROXY
}

Enum MajorityType {
  SIMPLE_MAJORITY
  TWO_THIRDS
  FOUR_FIFTHS
  UNANIMOUS
  PLURALITY
}

Enum DocumentVisibility {
  PUBLIC
  BOARD_ONLY
  ADMIN_ONLY
}

Enum BuildingRole {
  SUPER_ADMIN
  ADMIN
  BOARD_MEMBER
  AUDITOR
  OWNER
  TENANT
}

Enum AuditorKind {
  COMMITTEE_MEMBER
  COMMITTEE_CHAIR
  REGISTERED_AUDITOR
}

Enum AnnouncementChannel {
  EMAIL
  PUSH
  PHYSICAL_BOARD
  SMS
}

Enum DeliveryStatus {
  QUEUED
  DELIVERED
  FAILED
  ACK_REQUIRED
}

Enum ArrearsDisclosureMode {
  INTERNAL_ONLY
  CLOSED_DELIVERY
}

Enum UnitRelationship {
  OWNER
  TENANT
}

Enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
}

Enum InvitationType {
  ADMIN_SETUP
  USER_INVITE
}

Enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

Enum ResignationStatus {
  PENDING
  ACKNOWLEDGED
  WITHDRAWN
}

Enum TaskStatus {
  OPEN
  DONE
  ARCHIVED
}

Enum TaskPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

Enum ChannelKind {
  ANNOUNCEMENT
  TOPIC
  DM
  GROUP_DM
  BOARD
  PARTNER
}

Enum MessageKind {
  POST
  CHAT
  POLL
  SYSTEM
}

Enum PendingAgendaKind {
  COMPLAINT_ESCALATION
  BOARD_RESIGNATION
}

Enum ContractorPlan {
  FREE
  PRO
  PREMIUM
}

