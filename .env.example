# Database
DATABASE_URL="postgresql://condo:condo_secret@localhost:5432/condo_manager?schema=public"

# Test database — must point at a *separate* DB; vitest setup will swap
# DATABASE_URL to this value before running tests, and refuses to run if
# it equals DATABASE_URL or its DB name is not clearly test-suffixed.
# One-time setup: see tests/README.md.
TEST_DATABASE_URL="postgresql://condo:condo_secret@localhost:5432/condo_manager_test?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# NextAuth
NEXTAUTH_SECRET="your-secret-key-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# SMTP (MailHog in development)
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@condo-manager.local"

# VAPID keys for Web Push notifications
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"
VAPID_SUBJECT="mailto:admin@condo-manager.local"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
